# Jina AI — get a free API key at https://jina.ai
JINA_API_KEY=jina_...

# Elasticsearch — use http://localhost:9200 for local Docker
# or your Elastic Cloud / Serverless URL
ES_URL=http://localhost:9200

# ES API key — leave blank for local Docker (security disabled)
# Required for secured clusters (Elastic Cloud, Serverless)
ES_API_KEY=

# Pexels — only needed to run scripts/download_pexels.py
# Get a free key at https://www.pexels.com/api/
PEXELS_API_KEY=

# Optional overrides
# WATCH_DIR=./clips          # initial library folder (UI can change this)
# CHUNKS_DIR=./chunks        # app-owned scene chunks + manifests
# BROLL_INDEX=broll
